      "id": 1,
      "title": "E-Commerce Latência de Rede (p95 / p99 em Segundos)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum(rate(ecommerce_http_latency_seconds_bucket[5m])) by (le, store_name))",
          "legendFormat": "{{store_name}} (p95)",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum(rate(ecommerce_http_latency_seconds_bucket[5m])) by (le, store_name))",
          "legendFormat": "{{store_name}} (p99)",
          "range": true,
          "refId": "B"
        }
      ]
