      "id": 9,
      "title": "SLA / Taxa de Sucesso dos Scrapers (%)",
      "type": "gauge",
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 85 },
              { "color": "green", "value": 95 }
            ]
          },
          "unit": "percent"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "(sum(increase(sku_observations_saved_total{gpu_model=~\"$gpu_model\"}[1h])) / sum(increase(sku_processing_duration_seconds_count{gpu_model=~\"$gpu_model\"}[1h]))) * 100",
          "legendFormat": "Taxa de Sucesso Global",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
